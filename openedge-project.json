{
  "name": "Ejemplo",
  "version": "1.0",
  "oeversion": "12.8",
  "graphicalMode": true,
  "charset": "utf-8",
  "includeFileExtensions": [
    ".i",
    ".f"
  ],
  "buildPath": [
    {
      "type": "source",
      "path": "src/main"
    },
    {
      "path": "build",
      "type": "propath"
    }
  ],
  "buildDirectory": "build",
  "dbConnections": [
    {
      "name": "sports2000",
      "schemaFile": "data/schema/sports2000.df",
      "connect": "-db sports2000 -H localhost -S 20000 -ld sports2000"
    }
  ]
}
